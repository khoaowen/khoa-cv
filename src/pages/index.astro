---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import CvSections from '../components/CvSections.astro';

const entry = await getEntry('cv', 'en');
if (!entry) throw new Error('Missing CV content: src/content/cv/en.yaml');
const { data } = entry;
---

<Base data={data} locale="en" pdfHref="/cv-en.pdf">
  <CvSections data={data} locale="en" />
</Base>
