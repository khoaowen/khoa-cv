---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';
import { dateRange } from '../lib/format';

interface Props {
  data: CollectionEntry<'cv'>['data'];
  locale: Locale;
  // 'web' (default) always shows full entries. 'print' condenses roles flagged
  // `condensed: true` into compact one-liners under "Earlier experience".
  variant?: 'web' | 'print';
}
const { data, locale, variant = 'web' } = Astro.props;
const t = useTranslations(locale);
const present = t('date.present');

// In print, split full vs. condensed roles; on the web, everything is "full".
const fullWork = variant === 'print' ? data.work.filter((j) => !j.condensed) : data.work;
const earlierWork = variant === 'print' ? data.work.filter((j) => j.condensed) : [];
---

<section class="cv-section" id="summary" aria-labelledby="h-summary">
  <h2 id="h-summary">{t('nav.summary')}</h2>
  <p class="summary">{data.basics.summary}</p>
</section>

{
  fullWork.length > 0 && (
    <section class="cv-section" id="experience" aria-labelledby="h-exp">
      <h2 id="h-exp">{t('nav.experience')}</h2>
      {fullWork.map((job) => (
        <article class="entry">
          <div class="entry-head">
            <div>
              <p class="entry-title">
                {job.position} — {job.company}
              </p>
              {job.location && <p class="entry-sub">{job.location}</p>}
            </div>
            <span class="entry-dates">{dateRange(job.start, job.end, present)}</span>
          </div>
          {variant === 'web' && job.introduction && (
            <>
              <p class="entry-detail-label">{t('experience.introduction')}</p>
              <p class="entry-sub">{job.introduction}</p>
            </>
          )}
          {job.summary && (
            <>
              {variant === 'web' && <p class="entry-detail-label">{t('experience.contribution')}</p>}
              <p class="entry-sub">{job.summary}</p>
            </>
          )}
          {job.highlights.length > 0 && (
            <>
              {variant === 'web' && <p class="entry-detail-label">{t('experience.responsibilities')}</p>}
              <ul>
                {job.highlights.map((h) => (
                  <li>{h}</li>
                ))}
              </ul>
            </>
          )}
          {variant === 'web' && job.impacts.length > 0 && (
            <>
              <p class="entry-detail-label">{t('experience.impact')}</p>
              <ul>
                {job.impacts.map((impact) => (
                  <li>{impact}</li>
                ))}
              </ul>
            </>
          )}
          {job.tech.length > 0 && (
            <>
              {variant === 'web' && <p class="entry-detail-label">{t('experience.environment')}</p>}
              <ul class="tags" aria-label={t('experience.environment')}>
                {job.tech.map((x) => (
                  <li>{x}</li>
                ))}
              </ul>
            </>
          )}
        </article>
      ))}
    </section>
  )
}

{
  earlierWork.length > 0 && (
    <section class="cv-section" id="earlier" aria-labelledby="h-earlier">
      <h2 id="h-earlier">{t('nav.earlier')}</h2>
      {earlierWork.map((job) => (
        <p class="condensed-entry">
          <strong>{job.position}</strong> — {job.company}
          <span class="entry-dates"> · {dateRange(job.start, job.end, present)}</span>
        </p>
      ))}
    </section>
  )
}

{
  data.projects.length > 0 && (
    <section class="cv-section" id="projects" aria-labelledby="h-proj">
      <h2 id="h-proj">{t('nav.projects')}</h2>
      {data.projects.map((p) => (
        <article class="entry">
          <p class="entry-title">
            {p.url ? (
              <a href={p.url} rel="noopener noreferrer">
                {p.name}
              </a>
            ) : (
              p.name
            )}
          </p>
          {p.description && <p class="entry-sub">{p.description}</p>}
          {p.tech.length > 0 && (
            <ul class="tags" aria-label="Technologies">
              {p.tech.map((x) => (
                <li>{x}</li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </section>
  )
}

{
  data.skills.length > 0 && (
    <section class="cv-section" id="skills" aria-labelledby="h-skills">
      <h2 id="h-skills">{t('nav.skills')}</h2>
      {data.skills.map((s) => (
        <div class="skill-row">
          <span class="cat">{s.category}</span>
          <span>{s.items.join(', ')}</span>
        </div>
      ))}
    </section>
  )
}


{
  data.softSkills.length > 0 && (
    <section class="cv-section" id="soft-skills" aria-labelledby="h-soft-skills">
      <h2 id="h-soft-skills">{t("nav.softSkills")}</h2>
      <ul class="soft-skill-list">
        {data.softSkills.map((skill) => (
          <li>{skill}</li>
        ))}
      </ul>
    </section>
  )
}

{
  data.education.length > 0 && (
    <section class="cv-section" id="education" aria-labelledby="h-edu">
      <h2 id="h-edu">{t('nav.education')}</h2>
      {data.education.map((ed) => (
        <article class="entry">
          <div class="entry-head">
            <div>
              <p class="entry-title">
                {[ed.studyType, ed.area].filter(Boolean).join(' — ')}
              </p>
              <p class="entry-sub">{ed.institution}</p>
            </div>
            <span class="entry-dates">{dateRange(ed.start, ed.end, present)}</span>
          </div>
          {ed.note && <p class="entry-sub">{ed.note}</p>}
        </article>
      ))}
    </section>
  )
}

{
  data.certifications.length > 0 && (
    <section class="cv-section" id="certifications" aria-labelledby="h-cert">
      <h2 id="h-cert">{t('nav.certifications')}</h2>
      <ul class="cert-list">
        {data.certifications.map((c) => (
          <li>
            <strong>{c.name}</strong>
            {c.issuer && <span> — {c.issuer}</span>}
            {c.date && <span> ({c.date})</span>}
          </li>
        ))}
      </ul>
    </section>
  )
}

{
  data.languages.length > 0 && (
    <section class="cv-section" id="languages" aria-labelledby="h-lang">
      <h2 id="h-lang">{t('nav.languages')}</h2>
      <ul class="lang-list">
        {data.languages.map((l) => (
          <li>
            <strong>{l.language}</strong>
            {l.fluency && <span> — {l.fluency}</span>}
          </li>
        ))}
      </ul>
    </section>
  )
}

{
  data.sideProjects.length > 0 && (
    <section class="cv-section" id="side-projects" aria-labelledby="h-side-projects">
      <h2 id="h-side-projects">{t('nav.sideProjects')}</h2>
      {data.sideProjects.map((p) => (
        <article class="entry">
          <p class="entry-title">{p.name}</p>
          {p.description && <p class="entry-sub">{p.description}</p>}
          {p.tech.length > 0 && (
            <ul class="tags" aria-label="Technologies">
              {p.tech.map((x) => (
                <li>{x}</li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </section>
  )
}
