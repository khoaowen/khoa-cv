---
import { getEntry } from 'astro:content';
import PrintLayout from '../../layouts/PrintLayout.astro';
import CvSections from '../../components/CvSections.astro';

// Print-only route rendered to dist/cv-fr.pdf by scripts/gen-pdf.mjs.
const entry = await getEntry('cv', 'fr');
if (!entry) throw new Error('Missing CV content: src/content/cv/fr.yaml');
const { data } = entry;
---

<PrintLayout data={data} locale="fr">
  <CvSections data={data} locale="fr" />
</PrintLayout>
