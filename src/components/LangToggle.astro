---
import type { Locale } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

// EN lives at "/", FR at "/fr/". Pure links — no JavaScript needed.
const links: { code: Locale; href: string; label: string }[] = [
  { code: 'en', href: '/', label: 'EN' },
  { code: 'fr', href: '/fr/', label: 'FR' },
];
---

<nav class="lang-toggle" aria-label={t('lang.label')}>
  {
    links.map((l) => (
      <a
        href={l.href}
        hreflang={l.code}
        aria-current={l.code === locale ? 'true' : undefined}
        lang={l.code}
      >
        {l.label}
      </a>
    ))
  }
</nav>
